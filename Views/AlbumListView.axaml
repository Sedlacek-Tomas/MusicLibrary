<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MusicLibrary.ViewModels"
             xmlns:models="using:MusicLibrary.Models"
             x:Class="MusicLibrary.Views.AlbumListView"
             x:DataType="vm:AlbumListViewModel">

  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">

    <TextBlock Grid.Row="0" Text="🎵 Hudební sbírka"
               FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>

    <!-- Vyhledávání + řazení -->
    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,12">
      <TextBox Grid.Column="0"
               Watermark="🔍 Hledat podle názvu, interpreta nebo žánru…"
               Text="{Binding SearchText}"
               Margin="0,0,8,0"/>
      <TextBlock Grid.Column="1" VerticalAlignment="Center"
                 Text="Řadit:" Margin="0,0,6,0"/>
      <ComboBox Grid.Column="2"
                ItemsSource="{Binding SortOptions}"
                SelectedItem="{Binding SortBy}"
                MinWidth="100"/>
    </Grid>

    <ListBox Grid.Row="2"
             ItemsSource="{Binding Albums}"
             SelectedItem="{Binding SelectedAlbum}">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="models:Album">
          <Border Padding="8" CornerRadius="4">
            <Grid ColumnDefinitions="*,Auto,Auto">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding Title}"/>
                <TextBlock FontSize="12" Opacity="0.7" Text="{Binding Artist}"/>
                <TextBlock FontSize="11" Opacity="0.5" Text="{Binding GenreName}"/>
              </StackPanel>
              <TextBlock Grid.Column="1" VerticalAlignment="Center"
                         Margin="8,0" Opacity="0.5" Text="{Binding Year}"/>
              <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <Button Content="Detail"
                        Command="{Binding $parent[UserControl].((vm:AlbumListViewModel)DataContext).OpenDetailCommand}"
                        CommandParameter="{Binding}"/>
                <Button Content="🗑"
                        Command="{Binding $parent[UserControl].((vm:AlbumListViewModel)DataContext).DeleteAlbumCommand}"
                        CommandParameter="{Binding}"/>
              </StackPanel>
            </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <StackPanel Grid.Row="3" Orientation="Horizontal"
                HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
      <Button Content="📊 Statistiky" Command="{Binding OpenStatsCommand}"/>
      <Button Content="+ Přidat album" Command="{Binding OpenAddFormCommand}" Padding="12,6"/>
    </StackPanel>

  </Grid>
</UserControl>