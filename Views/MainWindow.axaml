        x:Class="MusicLibrary.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Hudební sbírka"
        Width="800" Height="600"
        WindowStartupLocation="CenterScreen">

    <ContentControl Content="{Binding CurrentViewModel}"/>

